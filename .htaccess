# ===================================================================
# Dätwyler Küchenbau & Schreinerei AG — Apache/LiteSpeed Konfiguration
# Für statisches Hosting (z. B. Hostinger) der gebauten Single-Page-App.
# ===================================================================

# --- HTTPS erzwingen ------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Auf HTTPS umleiten (auch hinter Proxy/Load-Balancer)
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # --- SPA-Fallback: alle nicht existierenden Pfade auf index.html ---
  # Echte Dateien und Verzeichnisse werden direkt ausgeliefert,
  # alles andere (z. B. /kontakt, /leistungen/kuechen) rendert die App.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# --- Verzeichnis-Listing deaktivieren -------------------------------
Options -Indexes

# --- Zugriff auf versteckte Dateien (.env, .htaccess, .git …) sperren
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# --- Sicherheits-Header ---------------------------------------------
<IfModule mod_headers.c>
  # Kein MIME-Sniffing
  Header always set X-Content-Type-Options "nosniff"
  # Clickjacking-Schutz
  Header always set X-Frame-Options "SAMEORIGIN"
  # Referrer sparsam senden
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Sensible Browser-Features standardmässig aus
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
  # HSTS: Browser merkt sich HTTPS (1 Jahr, inkl. Subdomains)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # Content-Security-Policy — erlaubt nur benötigte Quellen:
  #  - Bilder: eigene Domain, data-URIs und das Higgsfield-Bild-CDN
  #  - Frames: Google-Maps-Embed auf der Kontaktseite
  #  - Styles inline (React setzt Inline-Styles / Farbverläufe)
  Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data: https://d8j0ntlcm91z4.cloudfront.net; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self'; connect-src 'self'; frame-src https://www.google.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"
</IfModule>

# --- Kompression ----------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml \
    application/javascript application/json application/xml \
    image/svg+xml application/rss+xml
</IfModule>

# --- Caching (Ablaufzeiten) -----------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # Gehashte Assets (JS/CSS/Fonts/Bilder) — 1 Jahr
  <FilesMatch "\.(js|css|woff2?|ttf|eot|otf|jpe?g|png|gif|webp|avif|svg|ico|mp4)$">
    ExpiresDefault "access plus 1 year"
  </FilesMatch>

  # index.html nie cachen — sonst sehen Besucher alte Versionen
  <FilesMatch "\.(html)$">
    ExpiresDefault "access plus 0 seconds"
  </FilesMatch>

  # Kurzlebige Metadateien
  <FilesMatch "(sitemap\.xml|robots\.txt)$">
    ExpiresDefault "access plus 1 day"
  </FilesMatch>
</IfModule>

# --- Caching (Cache-Control-Header) ---------------------------------
<IfModule mod_headers.c>
  # Gehashte Assets sind unveränderlich → aggressiv cachen
  <FilesMatch "\.(js|css|woff2?|ttf|eot|otf|jpe?g|png|gif|webp|avif|svg|ico|mp4)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # index.html immer frisch prüfen
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# --- Korrekte MIME-Typen (Fallback) ---------------------------------
<IfModule mod_mime.c>
  AddType application/json .json
  AddType image/svg+xml .svg
  AddType font/woff2 .woff2
  AddType video/mp4 .mp4
</IfModule>

# --- Eigene 404-Seite: SPA übernimmt das Routing --------------------
ErrorDocument 404 /index.html
